# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/studynotion
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/studynotion
MONGO_URI=mongodb://localhost:27017/studynotion

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# ─── Client ───────────────────────────────────────────────────────────────────
# The URL the React dev server runs on (used for CORS allow-list)
CLIENT_URL=http://localhost:3000
